{
  "manifest_version": 3,
  "name": "Chrome Tab Monitor",
  "version": "2.0.0",
  "description": "Monitor and control the number of tabs per window with automatic closing and real-time statistics",
  "permissions": ["tabs", "storage", "notifications", "windows"],
  "storage": {
    "managed_schema": "schema.json"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Tab Monitor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["window-limit-warning.html", "window-limit-warning.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
